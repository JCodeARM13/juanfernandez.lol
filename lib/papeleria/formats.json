      "controls": [
        { "key": "xHeight", "label": "Altura x (mm)", "type": "range", "min": 5, "max": 18, "step": 0.5 },
        { "key": "rowGap", "label": "Espacio entre renglones (mm)", "type": "range", "min": 3, "max": 14, "step": 0.5 }
