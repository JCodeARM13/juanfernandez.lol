{
  "meta": {
    "name": "Papelería",
    "version": "1.0.0",
    "units": "mm",
    "sizes": ["A4", "Carta", "A5", "A3", "A6", "Oficio"],
    "universalControls": [
      { "key": "size", "label": "Tamaño", "type": "select", "options": ["A4", "Carta", "A5", "A3", "A6", "Oficio"] },
      { "key": "orientation", "label": "Orientación", "type": "select", "options": ["portrait", "landscape"] },
      { "key": "lineColor", "label": "Color de línea", "type": "color" },
      { "key": "bgColor", "label": "Color de fondo", "type": "color" },
      { "key": "lineWeight", "label": "Grosor (mm)", "type": "range", "min": 0.08, "max": 0.8, "step": 0.02 },
      { "key": "margin", "label": "Margen (mm)", "type": "range", "min": 0, "max": 25, "step": 1 }
    ]
  },
  "formats": [
    {
      "id": "grid", "name": "Cuadrícula", "cat": "Cuaderno", "draw": "grid",
