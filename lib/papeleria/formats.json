      "controls": [
        { "key": "startHour", "label": "Hora inicio", "type": "range", "min": 0, "max": 12, "step": 1 },
        { "key": "endHour", "label": "Hora fin", "type": "range", "min": 13, "max": 24, "step": 1 }
      ]
    },
    {
      "id": "planner-week", "name": "Planner semanal", "cat": "Estudio", "draw": "plannerWeek",
