        { "key": "box", "label": "Casillas", "type": "bool" }
      ]
    },

    {
      "id": "music-staff", "name": "Pentagrama", "cat": "Música", "draw": "staff",
      "desc": "Pentagramas en blanco para música.",
      "params": { "staves": 12, "staffGap": 1.8, "lineColor": "#7a7a7a", "lineWeight": 0.22, "margin": 14 },
      "controls": [
        { "key": "staves", "label": "Pentagramas", "type": "range", "min": 4, "max": 18, "step": 1 },
        { "key": "staffGap", "label": "Sep. líneas (mm)", "type": "range", "min": 1.2, "max": 3, "step": 0.1 }
