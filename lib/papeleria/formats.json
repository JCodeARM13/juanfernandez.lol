      "params": { "habits": 15, "days": 31, "lineColor": "#c3ccd6", "margin": 10 },
      "controls": [
        { "key": "habits", "label": "Hábitos", "type": "range", "min": 5, "max": 30, "step": 1 },
        { "key": "days", "label": "Días", "type": "range", "min": 7, "max": 31, "step": 1 }
      ]
    },
    {
      "id": "todo", "name": "To-Do / checklist", "cat": "Estudio", "draw": "todo",
