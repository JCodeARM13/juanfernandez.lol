      "controls": [
        { "key": "cueWidth", "label": "Columna claves (mm)", "type": "range", "min": 40, "max": 80, "step": 1 },
        { "key": "summaryH", "label": "Resumen (mm)", "type": "range", "min": 25, "max": 70, "step": 1 },
        { "key": "lineSpacing", "label": "Interlínea (mm)", "type": "range", "min": 6, "max": 12, "step": 0.5 }
      ]
    },
    {
      "id": "planner-day", "name": "Planner diario", "cat": "Estudio", "draw": "plannerDay",
      "desc": "Agenda por horas + prioridades y notas.",
