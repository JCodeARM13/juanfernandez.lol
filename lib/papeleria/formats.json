      "params": { "weekStart": "mon", "lineSpacing": 8, "lineColor": "#c3ccd6", "lineWeight": 0.25, "margin": 10 },
      "controls": [
        { "key": "weekStart", "label": "Inicia en", "type": "select", "options": ["mon", "sun"] },
        { "key": "lineSpacing", "label": "Interlínea (mm)", "type": "range", "min": 5, "max": 12, "step": 0.5 }
      ]
    },
    {
      "id": "calendar-month", "name": "Calendario mensual", "cat": "Estudio", "draw": "calendar",
      "desc": "Rejilla mensual 7×6. Opcional: mes y año para numerar.",
      "params": { "weekStart": "mon", "lineColor": "#c3ccd6", "margin": 12 },
      "controls": [
        { "key": "weekStart", "label": "Inicia en", "type": "select", "options": ["mon", "sun"] },
        { "key": "month", "label": "Mes (1-12, opcional)", "type": "range", "min": 0, "max": 12, "step": 1 },
        { "key": "year", "label": "Año (opcional)", "type": "range", "min": 0, "max": 2100, "step": 1 }
      ]
    },
    {
      "id": "habit-tracker", "name": "Tracker de hábitos", "cat": "Estudio", "draw": "habit",
