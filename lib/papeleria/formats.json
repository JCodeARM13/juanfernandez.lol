    },
    {
      "id": "guitar-tab", "name": "Tablatura guitarra", "cat": "Música", "draw": "tab",
      "desc": "Tablatura de 6 cuerdas en grupos.",
      "params": { "groups": 8, "tabGap": 3, "lineColor": "#7a7a7a", "lineWeight": 0.22, "margin": 14 },
      "controls": [
        { "key": "groups", "label": "Grupos", "type": "range", "min": 4, "max": 14, "step": 1 },
